{
  "system": {
    "name": "ArcanisOS",
    "version": "1.0.0-alpha",
    "language": "en-US",
    "timezone": "UTC",
    "autoUpdate": true
  },
  "kernel": {
    "maxProcesses": 1024,
    "schedulerTickMs": 100,
    "securityLevel": "high"
  },
  "ai": {
    "model": "arcanis-brain-v1",
    "temperature": 0.7,
    "maxTokens": 2048,
    "memoryLimit": 10000,
    "autoLearn": true
  },
  "interface": {
    "theme": {
      "mode": "dark",
      "primaryColor": "#6366f1",
      "accentColor": "#22d3ee",
      "glassmorphism": true
    },
    "shell": {
      "aiMode": true,
      "historySize": 1000
    }
  },
  "security": {
    "encryption": true,
    "policy": "user",
    "auditLog": true
  },
  "development": {
    "defaultLanguage": "typescript",
    "buildOptimization": true
  }
}
