{
  "name": "@arcanis/developer-tools",
  "version": "0.1.0",
  "description": "Suite of developer tools for building Arcanis software",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "arc-debug": "dist/cli/index.js",
    "arc-profile": "dist/cli/index.js",
    "arc-analyze": "dist/cli/index.js",
    "arc-docgen": "dist/cli/index.js",
    "arc-test": "dist/cli/index.js",
    "arc-perfmon": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node dist/cli/index.js test",
    "lint": "node dist/cli/index.js analyze",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["arcanis", "developer-tools", "debugger", "profiler", "analyzer"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0"
  }
}
