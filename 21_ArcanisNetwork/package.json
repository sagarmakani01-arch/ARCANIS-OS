    "tcp-ip",
    "arcanis",
    "ai-native",
    "operating-system"
  ],
  "license": "MIT",
  "dependencies": {
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
