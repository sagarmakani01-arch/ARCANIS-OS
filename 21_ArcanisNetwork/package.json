{
  "name": "@arcanis/network",
  "version": "1.0.0-alpha",
  "description": "ArcanisNetwork - AI-native networking foundation for ArcanisOS",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
