{
  "name": "arcanis-compiler",
  "version": "0.1.0",
  "description": "ArcanisCompiler - A modular compiler for the ArcanisLang programming language",
  "main": "dist/index.js",
  "bin": {
    "arcanic": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ test/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["compiler", "language", "arcanis"],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
